{
  "get": {
    "operationId": "listProfiles",
    "summary": "Crop-profile library",
    "description": "All crop profiles (frontend data model §6, key [\"profiles\"]). Requires an authenticated viewer or operator (2b).",
    "x-slice": "2b",
    "security": [{ "bearerAuth": [] }],
    "responses": {
      "200": {
        "description": "The profile library.",
        "content": {
          "application/json": {
            "schema": {
              "type": "array",
              "items": { "$ref": "../components/schemas/profiles.json#/CropProfile" }
            }
          }
        }
      },
      "401": { "$ref": "../components/responses.json#/Unauthorized" }
    }
  },
  "post": {
    "operationId": "createProfile",
    "summary": "Create a crop profile",
    "description": "Add a profile to the library (operator only, 2b). The operator-chosen `id` slug identifies the profile.",
    "x-slice": "2b",
    "security": [{ "bearerAuth": [] }],
    "requestBody": {
      "required": true,
      "content": {
        "application/json": {
          "schema": { "$ref": "../components/schemas/profiles.json#/CropProfile" }
        }
      }
    },
    "responses": {
      "201": {
        "description": "The created profile.",
        "content": {
          "application/json": {
            "schema": { "$ref": "../components/schemas/profiles.json#/CropProfile" }
          }
        }
      },
      "401": { "$ref": "../components/responses.json#/Unauthorized" },
      "403": { "$ref": "../components/responses.json#/Forbidden" },
      "422": { "$ref": "../components/responses.json#/ValidationFailed" }
    }
  }
}
