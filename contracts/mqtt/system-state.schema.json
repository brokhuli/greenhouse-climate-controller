{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://greenhouse.local/contracts/mqtt/system-state.schema.json",
  "title": "Consolidated System State",
  "description": "Last-known full snapshot of one greenhouse, published RETAINED on gh/{greenhouse_id}/state so a subscriber has current state on connect (RFC-007 §2, controller spec §10). Greenhouse-scoped: envelope zone_id is null; per-zone detail lives in the zones array. Reuses the actuator and fault shapes from their owning schemas so the snapshot cannot drift from the per-topic messages.",
  "type": "object",
  "$defs": {
    "temperature_reading": {
      "type": ["object", "null"],
      "properties": { "value": { "type": "number" }, "unit": { "const": "°C" } },
      "required": ["value", "unit"],
      "additionalProperties": false
    },
    "humidity_reading": {
      "type": ["object", "null"],
      "properties": { "value": { "type": "number" }, "unit": { "const": "%RH" } },
      "required": ["value", "unit"],
      "additionalProperties": false
    },
    "co2_reading": {
      "type": ["object", "null"],
      "properties": { "value": { "type": "number" }, "unit": { "const": "ppm" } },
      "required": ["value", "unit"],
      "additionalProperties": false
    },
    "par_reading": {
      "type": ["object", "null"],
      "properties": { "value": { "type": "number" }, "unit": { "const": "µmol·m⁻²·s⁻¹" } },
      "required": ["value", "unit"],
      "additionalProperties": false
    },
    "vpd_reading": {
      "type": ["object", "null"],
      "properties": { "value": { "type": "number" }, "unit": { "const": "kPa" } },
      "required": ["value", "unit"],
      "additionalProperties": false
    },
    "soil_moisture_reading": {
      "type": ["object", "null"],
      "properties": { "value": { "type": "number" }, "unit": { "const": "%VWC" } },
      "required": ["value", "unit"],
      "additionalProperties": false
    },
    "controller": {
      "type": "object",
      "description": "Controller operating mode and health.",
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["normal", "degraded", "interlock"],
          "description": "normal = all loops nominal; degraded = a non-critical fault is active; interlock = a safety interlock is overriding control (controller spec §7)."
        },
        "healthy": {
          "type": "boolean",
          "description": "False when any active fault is present."
        }
      },
      "required": ["mode", "healthy"],
      "additionalProperties": false
    },
    "sensors": {
      "type": "object",
      "description": "Latest house-level sensor readings. Each is a {value, unit} pair with the unit fixed per metric, or null when unavailable.",
      "properties": {
        "temperature": { "$ref": "#/$defs/temperature_reading" },
        "humidity": { "$ref": "#/$defs/humidity_reading" },
        "co2": { "$ref": "#/$defs/co2_reading" },
        "par": { "$ref": "#/$defs/par_reading" },
        "vpd": { "$ref": "#/$defs/vpd_reading" }
      },
      "required": ["temperature", "humidity", "co2", "par", "vpd"],
      "additionalProperties": false
    },
    "zone_entry": {
      "type": "object",
      "properties": {
        "zone_id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
        },
        "soil_moisture": { "$ref": "#/$defs/soil_moisture_reading" },
        "irrigation": { "$ref": "https://greenhouse.local/contracts/mqtt/actuator-state.schema.json#/$defs/state" },
        "faulted": {
          "type": "boolean",
          "description": "True when this zone's irrigation is disabled by a fault (controller spec §7, §8)."
        }
      },
      "required": ["zone_id", "soil_moisture", "irrigation", "faulted"],
      "additionalProperties": false
    },
    "actuator_entry": {
      "type": "object",
      "properties": {
        "actuator": { "$ref": "https://greenhouse.local/contracts/mqtt/actuator-state.schema.json#/$defs/name" },
        "state": { "$ref": "https://greenhouse.local/contracts/mqtt/actuator-state.schema.json#/$defs/state" },
        "overridden": { "$ref": "https://greenhouse.local/contracts/mqtt/actuator-state.schema.json#/$defs/overridden" }
      },
      "required": ["actuator", "state", "overridden"],
      "additionalProperties": false
    },
    "fault_summary": {
      "type": "object",
      "properties": {
        "component": { "$ref": "https://greenhouse.local/contracts/mqtt/fault-event.schema.json#/$defs/component" },
        "zone_id": { "$ref": "https://greenhouse.local/contracts/mqtt/envelope.schema.json#/$defs/zone_id" },
        "fault_type": { "$ref": "https://greenhouse.local/contracts/mqtt/fault-event.schema.json#/$defs/fault_type" },
        "severity": { "$ref": "https://greenhouse.local/contracts/mqtt/fault-event.schema.json#/$defs/severity" }
      },
      "required": ["component", "fault_type", "severity"],
      "additionalProperties": false
    },
    "override_entry": {
      "type": "object",
      "properties": {
        "actuator": { "$ref": "https://greenhouse.local/contracts/mqtt/actuator-state.schema.json#/$defs/name" },
        "zone_id": { "$ref": "https://greenhouse.local/contracts/mqtt/envelope.schema.json#/$defs/zone_id" },
        "state": { "$ref": "https://greenhouse.local/contracts/mqtt/actuator-state.schema.json#/$defs/state" },
        "expires_at": {
          "type": ["string", "null"],
          "format": "date-time",
          "description": "When the override auto-expires (RFC 3339 UTC), or null for no timeout."
        }
      },
      "required": ["actuator", "state", "expires_at"],
      "additionalProperties": false
    }
  },
  "allOf": [
    { "$ref": "https://greenhouse.local/contracts/mqtt/envelope.schema.json" },
    {
      "properties": {
        "zone_id": {
          "const": null,
          "description": "Always null: the consolidated state is greenhouse-scoped."
        },
        "controller": { "$ref": "#/$defs/controller" },
        "sensors": { "$ref": "#/$defs/sensors" },
        "zones": {
          "type": "array",
          "description": "Per-zone irrigation state, one entry per configured zone.",
          "items": { "$ref": "#/$defs/zone_entry" }
        },
        "actuators": {
          "type": "array",
          "description": "Current state of every house-level actuator.",
          "items": { "$ref": "#/$defs/actuator_entry" }
        },
        "faults": {
          "type": "array",
          "description": "Active fault summaries. Empty when healthy.",
          "items": { "$ref": "#/$defs/fault_summary" }
        },
        "overrides": {
          "type": "array",
          "description": "Active manual overrides (controller spec §10). Empty when none.",
          "items": { "$ref": "#/$defs/override_entry" }
        }
      },
      "required": ["controller", "sensors", "zones", "actuators", "faults", "overrides"]
    }
  ],
  "unevaluatedProperties": false
}
