#!/usr/bin/env bash
set -e

export PATH="$HOME/.cargo/bin:$PATH"

echo "Running project checks..."

# Phase 1 (Rust) gate: format, lint, typecheck, test — scoped to climate-controller.
# Only run when staged changes touch the crate, so docs-only / future Go/Python commits
# are not blocked on cargo. Mirrors the CLAUDE.md completion gate.
if git diff --cached --name-only | grep -q '^climate-controller/'; then
  echo "climate-controller changes staged — running Rust gate..."
  (
    cd climate-controller
    cargo fmt --all -- --check
    cargo clippy --all-targets --all-features -- -D warnings
    cargo check --all-targets
    cargo test
  )
fi

# Contracts gate: validate the JSON Schema / OpenAPI contracts and their example fixtures when any
# contract, the harness, or its manifest is staged. Mirrors the crate-scoped Rust gate above so
# docs-only commits are not blocked on Node. Requires `npm install` (ajv + @redocly/cli).
if git diff --cached --name-only | grep -qE '^(contracts/|scripts/validate-contracts|package(-lock)?\.json)'; then
  echo "contract changes staged — validating schemas + fixtures..."
  if [[ -d node_modules ]]; then
    npm run --silent validate:contracts
  else
    echo "  node_modules/ missing — run 'npm install' to enable the contracts gate; skipping." >&2
  fi
fi

echo "Checks passed."

# Bump PATCH version in VERSION file (e.g. 1.2.3 → 1.2.4)
if [[ -f "VERSION" ]]; then
  VERSION=$(cat VERSION)
  MAJOR=$(echo "$VERSION" | cut -d. -f1)
  MINOR=$(echo "$VERSION" | cut -d. -f2)
  PATCH=$(echo "$VERSION" | cut -d. -f3)
  NEW_VERSION="$MAJOR.$MINOR.$((PATCH + 1))"
  echo "$NEW_VERSION" > VERSION
  git add VERSION
  echo "Version bumped: $VERSION → $NEW_VERSION"
fi
