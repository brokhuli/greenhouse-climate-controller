{
  "realm": "greenhouse",
  "enabled": true,
  "sslRequired": "none",
  "displayName": "Verdant",
  "displayNameHtml": "<span>Verdant</span>",
  "loginTheme": "greenhouse",
  "roles": {
    "realm": [
      { "name": "gh-viewer", "description": "Read fleet, telemetry, analytics, status" },
      { "name": "gh-operator", "description": "Viewer plus every write-path action (platform security §3)" },
      { "name": "setpoints:write", "description": "Narrow service role: submit setpoints on POST /setpoints only (RFC-011, optimizer service account)" }
    ]
  },
  "clients": [
    {
      "clientId": "climate-frontend",
      "name": "Climate console (SPA)",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": ["http://localhost:8080/*"],
      "webOrigins": ["+"],
      "attributes": {
        "post.logout.redirect.uris": "http://localhost:8080/*"
      },
      "protocolMappers": [
        {
          "name": "climate-api-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.custom.audience": "climate-api",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "optimizer",
      "name": "Optimizer (service account)",
      "description": "Confidential client for the Phase-3 optimizer's client-credentials POST /setpoints token (RFC-011). Dormant unless the platform runs SERVICE_AUTH_MODE=oidc; the dev secret below must be rotated for any real deployment.",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "secret": "dev-optimizer-secret",
      "protocolMappers": [
        {
          "name": "climate-api-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.custom.audience": "climate-api",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "operator",
      "enabled": true,
      "email": "operator@example.com",
      "firstName": "Olive",
      "lastName": "Operator",
      "credentials": [{ "type": "password", "value": "operator", "temporary": false }],
      "realmRoles": ["gh-operator"]
    },
    {
      "username": "viewer",
      "enabled": true,
      "email": "viewer@example.com",
      "firstName": "Vera",
      "lastName": "Viewer",
      "credentials": [{ "type": "password", "value": "viewer", "temporary": false }],
      "realmRoles": ["gh-viewer"]
    },
    {
      "username": "service-account-optimizer",
      "enabled": true,
      "serviceAccountClientId": "optimizer",
      "realmRoles": ["setpoints:write"]
    }
  ]
}
