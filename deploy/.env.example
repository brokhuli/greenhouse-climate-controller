# Copy to deploy/.env and set secrets before bringing up the stack:
#   cp deploy/.env.example deploy/.env
#
# Used by deploy/docker-compose.yml.
#   POSTGRES_PASSWORD          — TimescaleDB superuser + the platform's DSN.
#   KEYCLOAK_ADMIN[_PASSWORD]  — Keycloak master-realm admin console login (2b auth).
#   GRAFANA_ADMIN[_PASSWORD]   — Grafana admin login (2b observability); defaults to admin/admin.
#   OLLAMA_MODEL               — (Phase 3) the local LLM the optimizer plans with; pulled on bring-up
#                                by fresh-run.sh. Must be in the provider's allowlist (spec 11).
#   COMPOSE_PROFILES /          (Phase 3) the LLM-backend switch — see the block at the bottom.
#   OPTIMIZER_LLM__ENDPOINT
#
# The greenhouse realm's login users (operator/operator, viewer/viewer) are seeded from
# deploy/keycloak/realm.json, not here.
POSTGRES_PASSWORD=greenhouse
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
GRAFANA_ADMIN=admin
GRAFANA_ADMIN_PASSWORD=admin

# ── (Phase 3) LLM backend: bundled ollama container (default) vs. your HOST ollama ───────────────────
# The optimizer plans against an Ollama server. Pick ONE backend by choosing a block below.
#
# CONTAINER (default): run a dedicated `ollama` container in the stack — self-contained and
#   reproducible. fresh-run.sh pulls OLLAMA_MODEL into its volume (first run downloads several GB).
COMPOSE_PROFILES=ollama-container
OPTIMIZER_LLM__ENDPOINT=http://ollama:11434
#
# HOST (reuse the Ollama already running on your machine — your models, no container, no re-download):
#   comment the two lines above and uncomment the two below. Needs host Ollama listening on :11434.
#COMPOSE_PROFILES=
#OPTIMIZER_LLM__ENDPOINT=http://host.docker.internal:11434

# (Phase 3) Local Ollama model. Default llama3.2 (3B) is CPU-friendly; qwen2.5:7b is higher quality but
# slower. Must be one the chosen backend has (host mode: `ollama list`; container mode: auto-pulled). To
# plan with a cloud model instead, set OPTIMIZER_LLM__PROVIDER=anthropic|openai on the optimizer service
# and supply PLANNER_API_KEY (never commit it) — not needed for the default path.
OLLAMA_MODEL=llama3.2
