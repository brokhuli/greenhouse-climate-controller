{
  "uid": "controller-fleet",
  "title": "Controller Fleet",
  "tags": ["greenhouse", "controller"],
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 39,
  "version": 3,
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "",
  "annotations": { "list": [] },
  "templating": {
    "list": [
      {
        "name": "greenhouse",
        "label": "Greenhouse",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(controller_ticks_total, greenhouse_id)",
        "definition": "label_values(controller_ticks_total, greenhouse_id)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "current": { "text": "All", "value": "$__all", "selected": false },
        "options": [],
        "regex": "",
        "sort": 1,
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Fleet at a glance",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "panels": []
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Controllers connected",
      "description": "Controllers whose MQTT event loop last reported a healthy connection.",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null } ] }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "auto",
        "orientation": "auto"
      },
      "targets": [
        { "refId": "A", "expr": "sum(controller_mqtt_connected{greenhouse_id=~\"$greenhouse\"}) or on() vector(0)", "legendFormat": "connected", "instant": true, "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "In interlock",
      "description": "Controllers in interlock (mode 2): critical safety condition, actuators disabled.",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "auto",
        "orientation": "auto"
      },
      "targets": [
        { "refId": "A", "expr": "count(controller_mode{greenhouse_id=~\"$greenhouse\"} == 2) or on() vector(0)", "legendFormat": "interlock", "instant": true, "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Degraded",
      "description": "Controllers in degraded mode (mode 1): warning-level faults, control continues.",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 1 } ] }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "auto",
        "orientation": "auto"
      },
      "targets": [
        { "refId": "A", "expr": "count(controller_mode{greenhouse_id=~\"$greenhouse\"} == 1) or on() vector(0)", "legendFormat": "degraded", "instant": true, "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Active faults (fleet)",
      "description": "Total faults active across the selected fleet this tick.",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 5 } ] }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "auto",
        "orientation": "auto"
      },
      "targets": [
        { "refId": "A", "expr": "sum(controller_active_faults{greenhouse_id=~\"$greenhouse\"}) or on() vector(0)", "legendFormat": "faults", "instant": true, "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Tick overruns/s",
      "description": "Ticks/s whose compute time exceeded the P1-PERF-3 100 ms budget. Should be zero.",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "min": 0,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 0.001 }, { "color": "red", "value": 1 } ] }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "orientation": "auto"
      },
      "targets": [
        { "refId": "A", "expr": "sum(rate(controller_tick_overruns_total{greenhouse_id=~\"$greenhouse\"}[5m]))", "legendFormat": "overruns", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "id": 7,
      "type": "stat",
      "title": "MQTT drops/s",
      "description": "Telemetry frames/s dropped under broker backpressure (P1-RESIL-3). Should be zero.",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "min": 0,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 0.001 }, { "color": "red", "value": 1 } ] }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "orientation": "auto"
      },
      "targets": [
        { "refId": "A", "expr": "sum(rate(controller_mqtt_frames_dropped_total{greenhouse_id=~\"$greenhouse\"}[5m]))", "legendFormat": "dropped", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "id": 8,
      "type": "row",
      "title": "Controller state over time",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "panels": []
    },
    {
      "id": 9,
      "type": "state-timeline",
      "title": "Controller mode",
      "description": "Operating mode per controller: normal / degraded / interlock.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 90, "lineWidth": 0 },
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null } ] },
          "mappings": [
            { "type": "value", "options": {
              "0": { "text": "normal", "color": "green", "index": 0 },
              "1": { "text": "degraded", "color": "yellow", "index": 1 },
              "2": { "text": "interlock", "color": "red", "index": 2 }
            } }
          ],
          "min": 0,
          "max": 2
        },
        "overrides": []
      },
      "options": {
        "mergeValues": true,
        "showValue": "auto",
        "alignValue": "left",
        "rowHeight": 0.9,
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        { "refId": "A", "expr": "controller_mode{greenhouse_id=~\"$greenhouse\"}", "legendFormat": "{{greenhouse_id}}", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "id": 10,
      "type": "state-timeline",
      "title": "MQTT connected",
      "description": "Whether each controller's MQTT event loop last reported a healthy connection.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 90, "lineWidth": 0 },
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null } ] },
          "mappings": [
            { "type": "value", "options": {
              "0": { "text": "down", "color": "red", "index": 0 },
              "1": { "text": "up", "color": "green", "index": 1 }
            } }
          ],
          "min": 0,
          "max": 1
        },
        "overrides": []
      },
      "options": {
        "mergeValues": true,
        "showValue": "auto",
        "alignValue": "left",
        "rowHeight": 0.9,
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        { "refId": "A", "expr": "controller_mqtt_connected{greenhouse_id=~\"$greenhouse\"}", "legendFormat": "{{greenhouse_id}}", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "id": 11,
      "type": "row",
      "title": "Fleet performance now",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "panels": []
    },
    {
      "id": 12,
      "type": "bargauge",
      "title": "Tick compute p95 by greenhouse",
      "description": "Per-controller tick compute p95. Budget P1-PERF-3 < 100 ms.",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 0.1 } ] }
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "legend": { "showLegend": false }
      },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.95, sum by (le, greenhouse_id) (rate(controller_tick_duration_seconds_bucket{greenhouse_id=~\"$greenhouse\"}[5m])))", "legendFormat": "{{greenhouse_id}}", "instant": true, "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "id": 13,
      "type": "bargauge",
      "title": "Process CPU % by greenhouse",
      "description": "Per-controller process CPU usage (may exceed 100% across cores).",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 50 }, { "color": "red", "value": 90 } ] }
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "legend": { "showLegend": false }
      },
      "targets": [
        { "refId": "A", "expr": "controller_process_cpu_percent{greenhouse_id=~\"$greenhouse\"}", "legendFormat": "{{greenhouse_id}}", "instant": true, "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "id": 14,
      "type": "bargauge",
      "title": "Resident memory by greenhouse",
      "description": "Per-controller RSS. Budget P1-PERF-4 <= 50 MB.",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "min": 0,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 52428800 } ] }
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "legend": { "showLegend": false }
      },
      "targets": [
        { "refId": "A", "expr": "controller_process_resident_memory_bytes{greenhouse_id=~\"$greenhouse\"}", "legendFormat": "{{greenhouse_id}}", "instant": true, "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "id": 21,
      "type": "row",
      "title": "Resource trends",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "panels": []
    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "Process CPU usage (% by greenhouse)",
      "description": "Per-controller process CPU usage over time (may exceed 100% across cores).",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "expr": "controller_process_cpu_percent{greenhouse_id=~\"$greenhouse\"}", "legendFormat": "{{greenhouse_id}}", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "id": 23,
      "type": "timeseries",
      "title": "Process memory RSS (by greenhouse)",
      "description": "Per-controller resident set size over time. Budget P1-PERF-4 <= 50 MB.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes", "min": 0, "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "expr": "controller_process_resident_memory_bytes{greenhouse_id=~\"$greenhouse\"}", "legendFormat": "{{greenhouse_id}}", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "id": 15,
      "type": "row",
      "title": "Rates & distributions",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 },
      "panels": []
    },
    {
      "id": 16,
      "type": "timeseries",
      "title": "Tick rate (ticks/s by greenhouse)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 33 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "cps", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "expr": "rate(controller_ticks_total{greenhouse_id=~\"$greenhouse\"}[5m])", "legendFormat": "{{greenhouse_id}}", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "id": 17,
      "type": "heatmap",
      "title": "Tick duration distribution",
      "description": "Per-tick compute-time histogram over time; reveals tail behavior across the fleet.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 33 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "custom": { "hideFrom": { "tooltip": false, "viz": false, "legend": false }, "scaleDistribution": { "type": "linear" } } }, "overrides": [] },
      "options": {
        "calculate": false,
        "cellGap": 1,
        "cellValues": { "unit": "short" },
        "color": { "mode": "scheme", "scheme": "Spectral", "steps": 64, "reverse": false, "exponent": 0.5, "fill": "dark-orange", "scale": "exponential" },
        "exemplars": { "color": "rgba(255,0,255,0.7)" },
        "filterValues": { "le": 1e-9 },
        "legend": { "show": true },
        "rowsFrame": { "layout": "auto" },
        "tooltip": { "mode": "single", "showColorScale": false, "yHistogram": false },
        "yAxis": { "axisPlacement": "left", "reverse": false, "unit": "s" }
      },
      "targets": [
        { "refId": "A", "expr": "sum by (le) (rate(controller_tick_duration_seconds_bucket{greenhouse_id=~\"$greenhouse\"}[5m]))", "format": "heatmap", "legendFormat": "{{le}}", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "id": 18,
      "type": "timeseries",
      "title": "MQTT publish vs dropped (frames/s)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 41 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "cps", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "expr": "sum by (greenhouse_id) (rate(controller_mqtt_frames_published_total{greenhouse_id=~\"$greenhouse\"}[5m]))", "legendFormat": "published {{greenhouse_id}}", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "refId": "B", "expr": "sum by (greenhouse_id) (rate(controller_mqtt_frames_dropped_total{greenhouse_id=~\"$greenhouse\"}[5m]))", "legendFormat": "dropped {{greenhouse_id}}", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "id": 19,
      "type": "barchart",
      "title": "Faults by type (over range)",
      "description": "Faults counted on their rising edge over the selected time range, by fault type.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 41 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 1, "fillOpacity": 80, "gradientMode": "none", "axisPlacement": "auto" } },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "xTickLabelRotation": 0,
        "showValue": "auto",
        "stacking": "none",
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        { "refId": "A", "expr": "sum by (type) (increase(controller_faults_total{greenhouse_id=~\"$greenhouse\"}[$__range]))", "legendFormat": "{{type}}", "instant": true, "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "id": 20,
      "type": "barchart",
      "title": "Config applies by endpoint (over range)",
      "description": "Runtime config writes accepted over REST during the selected time range, by endpoint.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 49 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 1, "fillOpacity": 80, "gradientMode": "none", "axisPlacement": "auto" } },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "xTickLabelRotation": 0,
        "showValue": "auto",
        "stacking": "none",
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        { "refId": "A", "expr": "sum by (endpoint) (increase(controller_config_applies_total{greenhouse_id=~\"$greenhouse\"}[$__range]))", "legendFormat": "{{endpoint}}", "instant": true, "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    }
  ]
}
