{
  "uid": "container-resources",
  "title": "Container Resources",
  "tags": ["greenhouse", "containers"],
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "",
  "annotations": { "list": [] },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Right now",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "panels": []
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Containers running",
      "description": "Stack containers cAdvisor is currently reporting (name=~greenhouse-*).",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "text", "value": null } ] }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "none",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "auto",
        "orientation": "auto"
      },
      "targets": [
        { "refId": "A", "expr": "count(container_last_seen{name=~\"greenhouse-.+\"})", "legendFormat": "containers", "instant": true, "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Total CPU in use (cores)",
      "description": "Sum of CPU cores consumed across all stack containers (rate over 5m).",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 2,
          "min": 0,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "text", "value": null } ] }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "none",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "orientation": "auto"
      },
      "targets": [
        { "refId": "A", "expr": "sum(rate(container_cpu_usage_seconds_total{name=~\"greenhouse-.+\"}[5m]))", "legendFormat": "cores", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Total memory in use",
      "description": "Sum of working-set memory across all stack containers.",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "min": 0,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "text", "value": null } ] }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "none",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "orientation": "auto"
      },
      "targets": [
        { "refId": "A", "expr": "sum(container_memory_working_set_bytes{name=~\"greenhouse-.+\"})", "legendFormat": "memory", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "id": 5,
      "type": "row",
      "title": "Per container",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "panels": []
    },
    {
      "id": 6,
      "type": "bargauge",
      "title": "CPU by container (cores)",
      "description": "CPU cores consumed per container (rate over 5m). Watch for a container pinned near its cpus limit.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short", "decimals": 3, "min": 0, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null } ] } },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "legend": { "showLegend": false }
      },
      "targets": [
        { "refId": "A", "expr": "sum by (name) (rate(container_cpu_usage_seconds_total{name=~\"greenhouse-.+\"}[5m]))", "legendFormat": "{{name}}", "instant": true, "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "id": 7,
      "type": "bargauge",
      "title": "Memory by container",
      "description": "Working-set memory per container. Watch for a container creeping toward its memory limit (leak signal).",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "bytes", "min": 0, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null } ] } },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "legend": { "showLegend": false }
      },
      "targets": [
        { "refId": "A", "expr": "sum by (name) (container_memory_working_set_bytes{name=~\"greenhouse-.+\"})", "legendFormat": "{{name}}", "instant": true, "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "id": 8,
      "type": "table",
      "title": "Uptime by container",
      "description": "Time since each container started. A recently-reset value flags a crash/restart.",
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "align": "auto", "cellOptions": { "type": "auto" }, "inspect": false },
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "text", "value": null } ] }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Container" },
            "properties": [ { "id": "unit", "value": "string" } ]
          }
        ]
      },
      "options": { "showHeader": true, "cellHeight": "sm", "footer": { "show": false } },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "id": true, "image": true, "instance": true, "job": true },
            "indexByName": { "name": 0, "Value": 1 },
            "renameByName": { "name": "Container", "Value": "Uptime" }
          }
        }
      ],
      "targets": [
        { "refId": "A", "expr": "time() - container_start_time_seconds{name=~\"greenhouse-.+\"}", "format": "table", "instant": true, "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "id": 9,
      "type": "row",
      "title": "Trends",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 21 },
      "panels": []
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "CPU usage (cores) by container",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 3, "min": 0, "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "expr": "sum by (name) (rate(container_cpu_usage_seconds_total{name=~\"greenhouse-.+\"}[5m]))", "legendFormat": "{{name}}", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Memory usage by container",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes", "min": 0, "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "expr": "sum by (name) (container_memory_working_set_bytes{name=~\"greenhouse-.+\"})", "legendFormat": "{{name}}", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Network I/O by container",
      "description": "Per-container network throughput — receive (rx) and transmit (tx), rate over 5m.",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 30 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "Bps", "min": 0, "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "expr": "sum by (name) (rate(container_network_receive_bytes_total{name=~\"greenhouse-.+\"}[5m]))", "legendFormat": "{{name}} rx", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "refId": "B", "expr": "sum by (name) (rate(container_network_transmit_bytes_total{name=~\"greenhouse-.+\"}[5m]))", "legendFormat": "{{name}} tx", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    }
  ]
}
